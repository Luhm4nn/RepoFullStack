    const encodedFechaFuncion = encodeURIComponent(fechaFormateada);
    const url = `/AsientoReservas/${idSala}/${encodedFechaFuncion}`;
    const response = await api.get(url);
    return response.data;
  } catch (error) {
    throw error;
  }
};

