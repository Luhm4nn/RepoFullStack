import jwt from 'jsonwebtoken';

const JWT_SECRET = process.env.JWT_SECRET;

/**
 * Middleware para verificar la autenticidad del token JWT enviado en las cookies.
 * Si el token es válido, adjunta la información del usuario al objeto `req`.
 * 
 * @param {Object} req - Objeto de solicitud de Express.
 * @param {Object} res - Objeto de respuesta de Express.
 * @param {Function} next - Función para pasar al siguiente middleware.
 * @returns {Object} Respuesta 401 si el token no está presente o no es válido.
 */
export function authMiddleware(req, res, next) {
  const token = req.cookies.accessToken;
  if (!token) {
    return res.status(401).json({ message: 'Token no proporcionado' });
  }
  try {
    const payload = jwt.verify(token, JWT_SECRET);
    req.user = { id: payload.id, rol: payload.rol };
    next();
  } catch (err) {
    return res.status(401).json({ message: 'Token inválido o expirado' });
  }
}
</file>

<file path="Backend/Middlewares/authorizeRoles.js">
/**
 * Middleware para restringir el acceso a rutas basado en el rol del usuario.
 * Debe ejecutarse después de `authMiddleware`.
 * 
 * @param {...string} rolesPermitidos - Lista de roles que tienen permiso para acceder.
 * @returns {Function} Middleware de Express que verifica el rol del usuario.
 */
export function authorizeRoles(...rolesPermitidos) {
  return (req, res, next) => {
    if (!req.user || !rolesPermitidos.includes(req.user.rol)) {
      return res.status(403).json({ message: 'No tienes permisos para acceder a este recurso' });
    }
    next();
  };
}
